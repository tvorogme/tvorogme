# Public site origin used for metadata and absolute URLs.
NEXT_PUBLIC_SITE_URL=https://tvorog.me
SITE_URL=https://tvorog.me

# Article translation API.
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
ARTICLE_TRANSLATION_CACHE_DIR=

# LoreLog ingestion and publisher.
CODEX_LORELOG_SECRET=
CODEX_LORELOG_SERVER=http://127.0.0.1:3000/api/codex-subscription/lorelog
CODEX_LORELOG_WORKSPACE=
CODEX_LORELOG_INDEX_PATH=
CODEX_HOME=

# Admin area. In production set a strong password or SHA-256 hash,
# plus a separate random session secret.
TVOROGME_ADMIN_USERNAME=admin
TVOROGME_ADMIN_PASSWORD=
TVOROGME_ADMIN_PASSWORD_SHA256=
TVOROGME_ADMIN_SESSION_SECRET=
TVOROGME_ADMIN_CONFIG_PATH=
